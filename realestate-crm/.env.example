# --- Database (managed PostgreSQL, e.g. Neon) ---
# Always require TLS for a hosted DB holding PII: append ?sslmode=require
# Neon example: postgresql://user:pass@ep-xxx.region.aws.neon.tech/db?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/realestate_crm?sslmode=require"

# --- Auth (Auth.js / NextAuth v5) ---
# Generate: openssl rand -base64 32
AUTH_SECRET="change-me"
# The two Google accounts allowed to sign in (comma-separated, lowercase)
ALLOWED_EMAILS="jordanielafontaine@gmail.com,mom@example.com"
# Which of the allowlisted accounts is the admin
ADMIN_EMAIL="jordanielafontaine@gmail.com"

# --- Google OAuth (Cloud Console → Credentials → OAuth client) ---
# Scopes requested: openid email profile + gmail.compose (drafts only, cannot send)
AUTH_GOOGLE_ID="your-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-client-secret"

# --- Anthropic (server-side only) ---
ANTHROPIC_API_KEY="sk-ant-..."

# --- Suppression hashing pepper (HMAC secret; keep stable + secret) ---
# Generate: openssl rand -hex 32
SUPPRESSION_PEPPER="change-me"

# --- Public base URL (used to build unsubscribe links in emails) ---
APP_BASE_URL="http://localhost:3000"
